<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR 도서 대출 현황 시스템</title>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        :root {
            --hoseo-blue: #007bff;
            --hoseo-red: #dc3545;
            --hoseo-grey: #6c757d;
            --hoseo-dark: #343a40;
            --hoseo-green: #28a745;
            --bg-light: #f8f9fa;
        }

        body {
            font-family: 'Pretendard', sans-serif;
            margin: 0; padding: 0;
            background-color: #fff;
            color: #333;
        }

        /* 헤더 */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            border-bottom: 2px solid var(--hoseo-dark);
        }

        .logo-text { font-size: 22px; font-weight: bold; color: #444; }
        .univ-logo { font-size: 18px; font-weight: bold; color: #222; }

        .container {
            max-width: 900px;
            margin: 30px auto;
            padding: 20px;
            text-align: center;
        }

        h1 { font-size: 26px; margin-bottom: 8px; }
        p.subtitle { color: #666; font-size: 14px; margin-bottom: 40px; }

        /* 1. 홈 선택 화면 */
        #view-home { display: flex; justify-content: center; gap: 20px; margin-top: 40px; }
        .choice-card {
            width: 280px;
            padding: 50px 20px;
            border: 1px solid #ddd;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: var(--bg-light);
        }
        .choice-card:hover { 
            transform: translateY(-8px); 
            border-color: var(--hoseo-blue);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }
        .choice-card .icon { font-size: 50px; margin-bottom: 20px; display: block; }

        /* 2. 상세 결과 화면 (팝업 스타일) */
        #view-result-detail {
            display: none;
            background: white;
            border: 2px solid var(--hoseo-blue);
            border-radius: 15px;
            padding: 30px;
            margin: 20px auto;
            max-width: 500px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        .status-badge {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 20px;
            color: white;
            font-weight: bold;
            margin-bottom: 15px;
        }
        .bg-loaned { background-color: var(--hoseo-red); }
        .bg-available { background-color: var(--hoseo-green); }

        /* 3. 액션 화면 (스캔/업로드) */
        #view-action { display: none; }
        #reader-wrapper {
            max-width: 500px;
            margin: 20px auto;
            border: 1px solid #ddd;
            padding: 10px;
            background: #f0f0f0;
        }
        #reader { width: 100%; }

        /* 공통 버튼 */
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin: 5px;
            font-size: 14px;
        }
        .btn-blue { background-color: var(--hoseo-blue); }
        .btn-red { background-color: var(--hoseo-red); }
        .btn-grey { background-color: var(--hoseo-grey); }
        .btn-green { background-color: var(--hoseo-green); }

        /* 기록 테이블 */
        .section-box {
            background: var(--bg-light);
            padding: 20px;
            border-radius: 8px;
            text-align: left;
            margin-top: 30px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            background: white;
        }
        th { background-color: var(--hoseo-dark); color: white; padding: 12px; font-size: 14px; }
        td { border: 1px solid #eee; padding: 10px; text-align: center; font-size: 14px; }

        .hidden { display: none !important; }
    </style>
</head>
<body>

<header>
    <div class="logo-text">QR 도서 대출 관리</div>
    <div class="univ-logo">HOSEO UNIVERSITY</div>
</header>

<div class="container">
    <h1>QR 실시간 도서 현황 시스템</h1>
    <p class="subtitle">QR 코드를 스캔하여 도서의 대출 가능 여부와 정보를 즉시 확인하세요.</p>

    <div id="view-home">
        <div class="choice-card" onclick="initAction('scan')">
            <span class="icon">📷</span>
            <h3>QR 인식 (찍기)</h3>
            <p>카메라로 QR을 직접 스캔합니다.</p>
        </div>
        <div class="choice-card" onclick="initAction('upload')">
            <span class="icon">📁</span>
            <h3>QR 업로드</h3>
            <p>QR 사진 파일을 선택합니다.</p>
        </div>
    </div>

    <div id="view-result-detail">
        <div id="res-badge"></div>
        <h2 id="res-title" style="margin: 10px 0;">도서명</h2>
        <p id="res-info" style="color: #666; margin-bottom: 20px;"></p>
        <div style="text-align: left; background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
            <p><strong>대출자:</strong> <span id="res-borrower">-</span></p>
            <p><strong>반납일:</strong> <span id="res-due">-</span></p>
        </div>
        <button class="btn btn-blue" style="width: 100%;" onclick="closeResult()">확인 및 계속 스캔</button>
    </div>

    <div id="view-action">
        <div id="controls">
            <button class="btn btn-blue" id="start-btn">QR 스캔 시작</button>
            <button class="btn btn-red" id="stop-btn">QR 스캔 중지</button>
            <button class="btn btn-grey" onclick="location.reload()">홈으로</button>
        </div>

        <div id="reader-wrapper">
            <div id="reader"></div>
            <input type="file" id="qr-input-file" accept="image/*" class="hidden" style="margin: 20px 0;">
            <p id="upload-msg" class="hidden" style="padding: 20px; font-weight: bold;">위의 [파일 선택] 버튼을 눌러 이미지를 올려주세요.</p>
        </div>

        <div class="section-box">
            <h3>수동 입력 테스트</h3>
            <div style="display: flex; gap: 10px; margin-top: 10px;">
                <input type="text" id="manual-input" style="flex:1; padding: 10px; border:1px solid #ddd; border-radius:4px;" placeholder="도서번호(예: BOOK-001) 입력">
                <button class="btn btn-green" onclick="processQR(document.getElementById('manual-input').value)">확인</button>
            </div>
        </div>

        <div class="section-box">
            <h3>최근 인식 기록</h3>
            <table>
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>도서번호</th>
                        <th>상태</th>
                        <th>시간</th>
                    </tr>
                </thead>
                <tbody id="history-body"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // 1. 도서 데이터베이스
    const bookData = {
        "BOOK-001": { title: "파이썬 데이터 구조와 알고리즘", author: "홍길동", status: "대출중", borrower: "김호서", due: "2026-05-10" },
        "BOOK-002": { title: "C#을 이용한 유니티 게임 제작", author: "이철수", status: "대출가능", borrower: "-", due: "-" },
        "BOOK-003": { title: "디지털 포렌식 사이버 수사 실무", author: "박영희", status: "대출중", borrower: "이벤처", due: "2026-05-15" }
    };

    let html5QrCode;
    let recordCount = 0;

    // 2. 화면 전환 및 초기화
    function initAction(type) {
        document.getElementById('view-home').style.display = 'none';
        document.getElementById('view-action').style.display = 'block';

        if (type === 'upload') {
            document.getElementById('start-btn').classList.add('hidden');
            document.getElementById('stop-btn').classList.add('hidden');
            document.getElementById('qr-input-file').classList.remove('hidden');
            document.getElementById('upload-msg').classList.remove('hidden');
            setupFileUpload();
        }
    }

    // 3. QR 스캔 로직 (카메라)
    document.getElementById('start-btn').addEventListener('click', () => {
        html5QrCode = new Html5Qrcode("reader");
        const config = { fps: 10, qrbox: { width: 250, height: 250 } };
        html5QrCode.start({ facingMode: "environment" }, config, (decodedText) => {
            processQR(decodedText);
            html5QrCode.stop();
        }).catch(err => alert("카메라를 찾을 수 없거나 권한이 없습니다."));
    });

    document.getElementById('stop-btn').addEventListener('click', () => {
        if (html5QrCode) html5QrCode.stop().then(() => alert("스캔 정지"));
    });

    // 4. 파일 업로드 로직
    function setupFileUpload() {
        const fileInput = document.getElementById('qr-input-file');
        fileInput.addEventListener('change', e => {
            if (e.target.files.length === 0) return;
            const fileReader = new Html5Qrcode("reader");
            fileReader.scanFile(e.target.files[0], true)
                .then(decodedText => processQR(decodedText))
                .catch(err => alert("QR 코드를 인식할 수 없습니다. 다른 사진을 올려주세요."));
        });
    }

    // 5. 핵심: 인식 결과 처리 및 상세 화면 표시
    function processQR(data) {
        const book = bookData[data];
        
        // 상세 화면 데이터 채우기
        const resDetail = document.getElementById('view-result-detail');
        const badge = document.getElementById('res-badge');
        
        if (book) {
            document.getElementById('res-title').innerText = book.title;
            document.getElementById('res-info').innerText = `${book.author} 저 | 코드: ${data}`;
            document.getElementById('res-borrower').innerText = book.borrower;
            document.getElementById('res-due').innerText = book.due;
            
            if (book.status === "대출중") {
                badge.innerHTML = `<span class="status-badge bg-loaned">대출 중</span>`;
            } else {
                badge.innerHTML = `<span class="status-badge bg-available">대출 가능</span>`;
            }
        } else {
            document.getElementById('res-title').innerText = "미등록 도서";
            document.getElementById('res-info').innerText = `코드: ${data}`;
            document.getElementById('res-borrower').innerText = "정보 없음";
            document.getElementById('res-due').innerText = "-";
            badge.innerHTML = `<span class="status-badge btn-grey">등록되지 않은 코드</span>`;
        }

        // 화면 전환
        document.getElementById('reader-wrapper').classList.add('hidden');
        resDetail.style.display = 'block';

        // 하단 테이블에 기록 추가
        addHistory(data, book ? book.status : "미등록");
    }

    function closeResult() {
        document.getElementById('view-result-detail').style.display = 'none';
        document.getElementById('reader-wrapper').classList.remove('hidden');
    }

    function addHistory(data, status) {
        recordCount++;
        const now = new Date();
        const timeStr = `${now.getHours()}:${String(now.getMinutes()).padStart(2, '0')}:${String(now.getSeconds()).padStart(2, '0')}`;
        const row = `<tr><td>${recordCount}</td><td>${data}</td><td>${status}</td><td>${timeStr}</td></tr>`;
        document.getElementById('history-body').insertAdjacentHTML('afterbegin', row);
    }
</script>

</body>
</html>
